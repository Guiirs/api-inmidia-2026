п»ҝ# Arquivo: .env.example
# Este ГғВ© um template para as variГғВЎveis de ambiente do BACKEND (Node.js/API).
# Copie este arquivo para .env (que deve estar no .gitignore) e preencha com seus valores.

# --- SeguranГғВ§a e AutenticaГғВ§ГғВЈo ---
# Chave secreta longa para assinar os tokens JWT (Use um gerador seguro)
JWT_SECRET="your_super_long_and_random_jwt_secret_here"

# --- Banco de Dados ---
# String de conexГғВЈo do MongoDB Atlas
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster-url>/?appName=cluster"

REDIS_ENABLED=true
# Host do servidor Redis (deixe vazio para desabilitar cache)
REDIS_HOST=localhost
# Porta do Redis
REDIS_PORT=6379
# Senha do Redis (deixe vazio se nГғВЈo tiver senha)
REDIS_PASSWORD=
# TTL padrГғВЈo do cache em segundos (300 = 5 minutos)
CACHE_TTL=300
# URL completa do Redis (usada pelo BullMQ)
REDIS_URL="redis://localhost:6379"

# --- ConfiguraГғВ§ГғВөes de Ambiente ---
# URL onde o frontend EstГЈo rodando (para o CORS)
CORS_ORIGIN="https://inmidia.futureoutdoors.com.br,http://localhost:5173,http://localhost:4173"
# URL do frontend (legado; manter apenas se outra integraГғЖ’ГӮВ§ГғЖ’ГӮВЈo usar)
FRONTEND_URL="http://localhost:5173"

# Porta em que o servidor backend irГғВЎ rodar
PORT=4000

# --- Logs e Debug ---
# Habilitar logs HTTP detalhados (true/false)
LOG_HTTP=false

# Habilitar logs detalhados do Gateway (true/false)
LOG_GATEWAY=false

# --- Cloudflare R2 (Armazenamento de Arquivos) ---
# O endpoint da sua conta R2
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com/<bucket_name>"

# Chave de Acesso (ID) do R2
R2_ACCESS_KEY_ID="your_r2_access_key_id_here"

# Chave de Acesso Secreta do R2
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key_here"

# Nome do bucket R2
R2_BUCKET_NAME="name-bucket-here"

# URL pГғВәblica do bucket (se configurada)
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# --- ServiГғВ§os Externos (PDF) ---
# Chave de API para o serviГғВ§o PDFRest
PDF_REST_API_KEY="your_pdfrest_api_key_xxxxxxxx"

# Endpoint do serviГғВ§o PDFRest
PDF_REST_ENDPOINT="https://api.pdfrest.com/pdf"

# --- WhatsApp Integration (Opcional) ---
# Habilitar/Desabilitar integraГғВ§ГғВЈo WhatsApp
WHATSAPP_ENABLED=false

# Nome do grupo WhatsApp para enviar relatГғВіrios (o sistema busca por este nome)
WHATSAPP_GROUP_NAME="Placas DisponГғВӯveis"

# Se nГғВЈo encontrar o grupo pelo nome, usar o primeiro grupo disponГғВӯvel (true/false)
WHATSAPP_USE_FIRST_GROUP=false

# HorГғВЎrio para envio do relatГғВіrio diГғВЎrio (formato HH:MM)
WHATSAPP_REPORT_HOUR="09:00"

# Fuso horГЎrio para agendamento (Vercel reserva o nome TZ)
APP_TIMEZONE="Europe/Lisbon"





# Metrics auth
# Configure para proteger o endpoint /metrics
METRICS_USER=metrics_reader
METRICS_PASSWORD=change_this_metrics_password
